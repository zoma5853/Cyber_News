# Copy this file to ".env" for local runs, or set these as
# Environment Variables in your Render dashboard.

# Required: token from @BotFather on Telegram
BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyz

# Optional: comma-separated chat IDs that ALWAYS get the daily digest.
# Get your chat ID by sending /start to the bot (it replies with your ID).
DIGEST_CHAT_IDS=123456789

# Optional overrides (defaults shown)
DIGEST_HOUR=9
DIGEST_MINUTE=0
TOP_N=8
